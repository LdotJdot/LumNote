      "role": "tool",
      "content": "== MarkdownEditor/Engine/Highlighting/MarkdownHighlightingService.cs ==\r\n     1|using MarkdownEditor.Core;\r\n     2|using MarkdownEditor.Engine.Document;\r\n     3|\r\n     4|namespace MarkdownEditor.Engine.Highlighting;\r\n     5|\r\n     6|/// \u003Csummary\u003E\r\n     7|/// \u57FA\u4E8E\u73B0\u6709 BlockScanner \u002B MarkdownParser \u7684 Markdown \u8BED\u6CD5\u9AD8\u4EAE\u5206\u6790\u5668\u3002\r\n     8|/// \u4E3A\u4E86\u5148\u6D88\u9664\u7F16\u8BD1\u9519\u8BEF\u5E76\u63D0\u4F9B\u57FA\u7840\u9AD8\u4EAE\uFF0C\u8FD9\u91CC\u91C7\u7528\u201C\u6574\u6587\u89E3\u6790 \u002B \u884C\u5185\u7B80\u5355\u6620\u5C04\u201D\u7684\u5B9E\u73B0\uFF0C\r\n     9|/// \u540E\u7EED\u53EF\u4EE5\u6309\u9700\u505A\u589E\u91CF/\u6309\u5757\u4F18\u5316\u3002\r\n    10|/// \u003C/summary\u003E\r\n    11|public sealed class MarkdownHighlightingService\r\n    12|{\r\n    13|    /// \u003Csummary\u003E\r\n    14|    /// \u5BF9\u6574\u7BC7\u6216\u6307\u5B9A\u884C\u8303\u56F4\u7684 Markdown \u6587\u672C\u8FDB\u884C\u8BED\u6CD5\u9AD8\u4EAE\u5206\u6790\u3002\r\n    15|    /// visibleStartLine / visibleEndLine \u4E3A\u53EF\u89C1\u884C\u53F7\uFF080-based\uFF0C\u542B\uFF09\uFF0C\u7528\u4E8E\u5728\u5927\u6587\u6863\u4E2D\u53EA\u5206\u6790\u53EF\u89C1\u7A97\u53E3\u9644\u8FD1\u7684\u5757\u3002\r\n    16|    /// \u4F20\u5165 null \u65F6\u5219\u626B\u63CF\u6574\u7BC7\u6587\u6863\u3002\r\n    17|    /// \u003C/summary\u003E\r\n    18|    public IReadOnlyList\u003CHighlightToken\u003E Analyze(string text, int? visibleStartLine = null, int? visibleEndLine = null)\r\n    19|    {\r\n    20|        if (string.IsNullOrEmpty(text))\r\n    21|            return Array.Empty\u003CHighlightToken\u003E();\r\n    22|\r\n    23|        var docSource = new StringDocumentSource(text);\r\n    24|        var tokens = new List\u003CHighlightToken\u003E();\r\n    25|\r\n    26|        int line = 0;\r\n    27|        while (line \u003C docSource.LineCount)\r\n    28|        {\r\n    29|            var span = BlockScanner.ScanNextBlock(docSource, line);\r\n    30|            if (span.LineCount \u003C= 0)\r\n    31|                break;\r\n    32|\r\n    33|            // \u82E5\u6307\u5B9A\u4E86\u53EF\u89C1\u7A97\u53E3\uFF0C\u5219\u4EC5\u5BF9\u4E0E\u7A97\u53E3\u6709\u4EA4\u96C6\u7684\u5757\u505A\u5206\u6790\uFF0C\u907F\u514D\u5728\u5927\u6587\u6863\u4E2D\u5BF9\u5B8C\u5168\u4E0D\u53EF\u89C1\u5757\u53CD\u590D\u89E3\u6790\u3002\r\n    34|            if (visibleStartLine.HasValue \u0026\u0026 visibleEndLine.HasValue)\r\n    35|            {\r\n    36|                int start = visibleStartLine.Value;\r\n    37|                int end = visibleEndLine.Value;\r\n    38|                if (span.EndLine \u003C= start)\r\n    39|                {\r\n    40|                    line = span.EndLine;\r\n    41|                    continue;\r\n    42|                }\r\n    43|                if (span.StartLine \u003E end)\r\n    44|                    break;\r\n    45|            }\r\n    46|\r\n    47|            AddBlockTokens(docSource, span, tokens, visibleStartLine, visibleEndLine);\r\n    48|            line = span.EndLine;\r\n    49|        }\r\n    50|\r\n    51|        return tokens;\r\n    52|    }\r\n    53|\r\n    54|    private static void AddBlockTokens(\r\n    55|        IDocumentSource doc,\r\n    56|        BlockSpan span,\r\n    57|        List\u003CHighlightToken\u003E output,\r\n    58|        int? visibleStartLine,\r\n    59|        int? visibleEndLine)\r\n    60|    {\r\n    61|        switch (span.Kind)\r\n    62|        {\r\n    63|            case BlockKind.Heading:\r\n    64|                AddHeadingTokens(doc, span, output, visibleStartLine, visibleEndLine);\r\n    65|                break;\r\n    66|            case BlockKind.CodeBlock:\r\n    67|                AddCodeBlockTokens(doc, span, output, visibleStartLine, visibleEndLine);\r\n    68|                break;\r\n    69|            case BlockKind.List:\r\n    70|                AddListTo