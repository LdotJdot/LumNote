      "role": "tool",
      "content": "== MarkdownEditor/config.sample.json ==\r\n     1|{\r\n     2|  \u0022ui\u0022: {\r\n     3|    \u0022documentListWidth\u0022: 280,\r\n     4|    \u0022editorWidth\u0022: 1,\r\n     5|    \u0022backgroundColor\u0022: \u0022#f6f8fa\u0022,\r\n     6|    \u0022sidebarBackground\u0022: \u0022#ffffff\u0022,\r\n     7|    \u0022headerBackground\u0022: \u0022#24292f\u0022,\r\n     8|    \u0022linkColor\u0022: \u0022#0566d2\u0022\r\n     9|  },\r\n    10|  \u0022markdown\u0022: {\r\n    11|    \u0022codeBlockBackground\u0022: \u0022#f6f8fa\u0022,\r\n    12|    \u0022codeBlockTextColor\u0022: \u0022#24262e\u0022,\r\n    13|    \u0022blockquoteBorderColor\u0022: \u0022#dfe2e6\u0022,\r\n    14|    \u0022tableBorderColor\u0022: \u0022#d0d7de\u0022,\r\n    15|    \u0022tableHeaderBackground\u0022: \u0022#f6f8fa\u0022,\r\n    16|    \u0022heading1Size\u0022: 28,\r\n    17|    \u0022heading2Size\u0022: 24,\r\n    18|    \u0022codeFontFamily\u0022: \u0022Cascadia Code,Consolas,Microsoft YaHei Mono,monospace\u0022,\r\n    19|    \u0022bodyFontFamily\u0022: \u0022Microsoft YaHei UI,Segoe UI,PingFang SC,sans-serif\u0022,\r\n    20|    \u0022linkColor\u0022: \u0022#0566d2\u0022\r\n    21|  }\r\n    22|}\r\n\r\n== MarkdownEditor/Helpers/UiStyleApplier.cs ==\r\n     1|using Avalonia.Controls;\r\n     2|using Avalonia.Media;\r\n     3|using MarkdownEditor.Core;\r\n     4|\r\n     5|namespace MarkdownEditor.Helpers;\r\n     6|\r\n     7|/// \u003Csummary\u003E\u5C06\u914D\u7F6E\u4E2D\u7684\u754C\u9762\u6837\u5F0F\u989C\u8272\u6CE8\u5165\u5230\u5E94\u7528\u8D44\u6E90\uFF0C\u4F9B DynamicResource \u4F7F\u7528\u3002\u003C/summary\u003E\r\n     8|public static class UiStyleApplier\r\n     9|{\r\n    10|    /// \u003Csummary\u003E\u5C06 \u003Cparamref name=\u0022style\u0022/\u003E \u5199\u5165 \u003Cparamref name=\u0022resources\u0022/\u003E\uFF0C\u952E\u4E0E XAML \u4E2D DynamicResource \u4E00\u81F4\u3002\u003C/summary\u003E\r\n    11|    public static void Apply(IResourceDictionary resources, UiStyleColors style)\r\n    12|    {\r\n    13|        if (resources == null || style == null) return;\r\n    14|\r\n    15|        Set(resources, \u0022WindowBackground\u0022, style.WindowBackground);\r\n    16|        Set(resources, \u0022TitleBarBackground\u0022, style.TitleBarBackground);\r\n    17|        Set(resources, \u0022TitleBarForeground\u0022, style.TitleBarForeground);\r\n    18|        Set(resources, \u0022SidebarBackground\u0022, style.SidebarBackground);\r\n    19|        Set(resources, \u0022SidebarBorderBrush\u0022, style.SidebarBorderBrush);\r\n    20|        Set(resources, \u0022SidebarHeaderBackground\u0022, style.SidebarHeaderBackground);\r\n    21|        Set(resources, \u0022SidebarTextForeground\u0022, style.SidebarTextForeground);\r\n    22|        Set(resources, \u0022ExplorerHeaderBackground\u0022, style.ExplorerHeaderBackground);\r\n    23|        Set(resources, \u0022ExplorerHeaderForeground\u0022, style.ExplorerHeaderForeground);\r\n    24|        Set(resources, \u0022WelcomePageBackground\u0022, style.WelcomePageBackground);\r\n    25|        Set(resources, \u0022WelcomePageTextForeground\u0022, style.WelcomePageTextForeground);\r\n    26|        Set(resources, \u0022WelcomePageLinkForeground\u0022, style.WelcomePageLinkForeground);\r\n    27|        Set(resources, \u0022TabBarBackground\u0022, style.TabBarBackground);\r\n    28|        Set(resources, \u0022TabBarBorderBrush\u0022, style.TabBarBorderBrush);\r\n    29|        Set(resources, \u0022ContentBackground\u0022, style.ContentBackground);\r\n    30|        Set(resources, \u0022EditorForeground\u0022, style.EditorForeground);\r\n    31|        Set(resources, \u0022StatusBarBackground\u0022, style.StatusBarBackground);\r\n    32|        Set(resources, \u0022StatusBarForeground\u0022, style.StatusBarForeground);\r\n    33|        Set(resources, \u0022FileChangedBarBackground\u0022, style.FileChangedBarBackground);\r\n    34|        Set(resources, \u0022FileChangedBarForeground\u0022, style.FileChangedBarForeground);\r\n    35|        Set(resources, \u0022ButtonForeground\u0022, style.ButtonForeground);\r\n    36|        Set(resources, \u0022ButtonHoverBackground\u0022, style.ButtonHoverBackground);\r\n    37|        Set(resources, \u0022ButtonPressedBackground\u0022, style.ButtonPressedBackground);\r\n    38|        Set(resources, \u0022TabItemForeground\u0022, style.TabItemForeground);\r\n    39|        Set(resources, \u0022TabItemSelectedForeground\u0022, style.TabItemSelectedForeground);\r\n    40|        Set(resources, \u0022TabItemHoverBackground\u0022, style.TabItemHoverBackground);\r\n    41|        Set(resources, \u0022TabItemSelectedBackground\u0022, style.TabItemSelectedBackground);\r\n    42|        Set(resources, \u0022TabItemSelectedUnderlineBrush\u0022, style.TabItemSelectedUnderline);\r\n    43|        Set(resources, \u0022InputBackground\u0022, style.InputBackground);\r\n    44|        Set(resources, \u0022InputForeground\u0022, style.InputForeground);\r\n    45|        Set(resources, \u0022InputBorderBrush\u0022, style.InputBorderBrush);\r\n    46|        Set(resources, \u0022SplitterBorderBrush\u0022, style.SplitterBorderBrush);\r\n    47|        Set(resources, \u0022ListBoxItemSelectedBackground\u0022, style.ListBoxItemSelectedBackground);\r\n    48|        Set(resources, \u0022ListBoxItemSelectedForeground\u0022, style.ListBoxItemSelectedForeground);\r\n    49|        Set(resources, \u0022DiffAddedBackground\u0022, style.DiffAddedBackground);\r\n    50|        Set(resources, \u0022DiffRemovedBackground\u0022, style.DiffRemovedBackground);\r\n    51|    }\r\n    52|\r\n    53|    private static void Set(IResourceDictionary resources, string key, string colorString)\r\n    54|    {\r\n    55|        var brush = ParseBrush(colorString);\r\n    56|        if (brush != null)\r\n    57|            resources[key] = brush;\r\n    58|    }\r\n    59|\r\n    60|    private static SolidColorBrush? ParseBrush(string? s)\r\n    61|    {\r\n    62|        if (string.IsNullOrWhiteSpace(s)) return null;\r\n    63|        s = s!.Trim();\r\n    64|        if (s.StartsWith(\u0022#\u0022, StringComparison.Ordinal))\r\n    65|        {\r\n    66|            var argb = ColorUtils.ParseHexColor(s);\r\n    67|            return new SolidColorBrush(Color.FromUInt32(argb));\r\n    68|        }\r\n    69|        if (KnownColors.TryGetValue(s, out var color))\r\n    70|            return new SolidColorBrush(color);\r\n    71|        return null;\r\n    72|    }\r\n    73|\r\n    74|    private static readonly Dictionary\u003Cstring, Color\u003E KnownColors = new(StringComparer.OrdinalIgnoreCase)\r\n    75|    {\r\n    76|        [\u0022White\u0022] = Color.FromUInt32(0xFFFFFFFF),\r\n    77|        [\u0022Black\u0022] = Color.FromUInt32(0xFF000000),\r\n    78|        [\u0022Transparent\u0022] = Color.FromUInt32(0x00FFFFFF),\r\n    79|    };\r\n    80|}\r\n\r\n== MarkdownEditor/Engine/EngineConfig.cs ==\r\n     1|using System;\r\n     2|using System.IO;\r\n     3|\r\n     4|namespace MarkdownEditor.Engine;\r\n     5|\r\n     6|/// \u003Csummary\u003E\r\n     7|/// \u6E32\u67D3\u5F15\u64CE\u914D\u7F6E - \u5B57\u4F53\u3001\u6837\u5F0F\u7B49\r\n     8|/// \u003C/summary\u003E\r\n     9|public sealed class EngineConfig\r\n    10|{\r\n    11|    public string BodyFontFamily { get; set; } =\r\n    12|        \u0022Microsoft YaHei UI,Segoe UI,PingFang SC,sans-serif\u0022;\r\n    13|    public string CodeFontFamily { get; set; } =\r\n    14|        \u0022Cascadia Code,Consolas,Microsoft YaHei Mono,monospace\u0022;\r\n    15|\r\n    16|    /// \u003Csummary\u003E\r\n    17|    /// \u6570\u5B66\u516C\u5F0F\u9996\u9009\u5B57\u4F53\u5217\u8868\uFF08\u9017\u53F7\u5206\u9694\uFF0C\u4F18\u5148\u7EA7\u4ECE\u5DE6\u5230\u53F3\uFF09\uFF0C\r\n    18|    /// \u5EFA\u8BAE\u5305\u542B Latin Modern Math / STIX Two Math / Cambria Math \u7B49\u652F\u6301 MATH \u8868\u7684\u5B57\u4F53\u3002\r\n    19|    /// \u003C/summary\u003E\r\n    20|    public string MathFontFamily { get; set; } =\r\n    21|        \u0022Latin Modern Math,STIX Two Math,Cambria Math,Times New Roman\u0022;\r\n    22|\r\n    23|    /// \u003Csummary\u003E\r\n    24|    /// \u53EF\u9009\uFF1A\u663E\u5F0F\u6307\u5B9A\u6570\u5B66\u5B57\u4F53\u6587\u4EF6\u8DEF\u5F84\uFF08OTF/TTF\uFF09\uFF0C\r\n    25|    /// \u82E5\u8BBE\u7F6E\u4E14\u5B58\u5728\uFF0C\u5219\u4F18\u5148\u901A\u8FC7 SKTypeface.FromFile \u52A0\u8F7D\u8BE5\u5B57\u4F53\u3002\r\n    26|    /// \u003C/summary\u003E\r\n    27|    public string? MathFontFilePath { get; set; } = DetectDefaultMathFontFilePath();\r\n    28|    public float BaseFontSize { get; set; } = 16;\r\n    29|    public float LineSpacing { get; set; } = 1.35f;\r\n    30|    public float ParaSpacing { get; set; } = 10f;\r\n    31|\r\n    32|    /// \u003Csummary\u003E\u9884\u89C8\u533A\u6574\u4F53\u7F29\u653E\uFF081f=100%\uFF09\uFF0C\u4F5C\u7528\u4E8E\u5B57\u53F7\u4E0E\u6240\u6709\u95F4\u8DDD\u3002\u003C/summary\u003E\r\n    33|    public float ZoomLevel { get; set; } = 1f;\r\n    34|\r\n    35|    /// \u003Csummary\u003E\u5217\u8868\u5757\u9876\u90E8/\u5E95\u90E8\u4E0E\u6BB5\u843D\u7684\u989D\u5916\u95F4\u8DDD\uFF08\u4F7F\u6BB5\u843D\u4E0E\u5217\u8868\u4E0D\u4F1A\u8D34\u592A\u8FD1\uFF09\u3002\u003C/summary\u003E\r\n    36|    public float ListBlockMarginTop { get; set; } = 6f;\r\n    37|    public float ListBlockMarginBottom { get; set; } = 6f;\r\n    38|    /// \u003Csummary\u003E\u5217\u8868\u9879\u4E0E\u4E0B\u4E00\u9879\u4E4B\u95F4\u7684\u989D\u5916\u95F4\u8DDD\u3002\u003C/summary\u003E\r\n    39|    public float ListItemGap { get; set; } = 3f;\r\n    40|\r\n    41|    /// \u003Csummary\u003E\u9884\u89C8\u533A\u5185\u5BB9\u5DE6\u53F3\u5185\u8FB9\u8DDD\uFF08\u4E0E\u5E03\u5C40\u5F15\u64CE\u534F\u8C03\uFF0C\u7528\u4E8E\u6D4B\u91CF/\u6EDA\u52A8\uFF09\u3002\u003C/summary\u003E\r\n    42|    public float ContentPaddingX { get; set; } = 24f;\r\n    43|\r\n    44|    /// \u003Csummary\u003E\u9884\u89C8\u533A\u5185\u5BB9\u4E0A\u4E0B\u5185\u8FB9\u8DDD\u3002\u003C/summary\u003E\r\n    45|    public float ContentPaddingY { get; set; } = 16f;\r\n    46|\r\n    47|    /// \u003Csummary\u003E\u5757\u7EA7\u5185\u5BB9\u5DE6\u4FA7\u7F29\u8FDB\uFF08\u4E0E\u89C6\u53E3\u8FB9\u7F18\u7684\u8DDD\u79BB\uFF09\u3002\u003C/summary\u003E\r\n    48|    public float BlockIndent { get; set; } = 14f;\r\n    49|\r\n    50|    /// \u003Csummary\u003E\u6587\u6863\u5E95\u90E8\u989D\u5916\u7559\u767D\u3002\u003C/summary\u003E\r\n    51|    public float ExtraBottomPadding { get; set; } = 8f;\r\n    52|\r\n    53|    /// \u003Csummary\u003E\u4EE3\u7801\u5757/HTML \u5757\u5185\u8FB9\u8DDD\u3002\u003C/summary\u003E\r\n    54|    public float CodeBlockPadding { get; set; } = 16f;\r\n    55|\r\n    56|    /// \u003Csummary\u003E\u5757\u5185\u6587\u672C\u4E0E\u5757\u8FB9\u7F18\u7684\u5185\u8FB9\u8DDD\u3002\u003C/summary\u003E\r\n    57|    public float BlockInnerPadding { get; set; } = 12f;\r\n    58|\r\n    59|    /// \u003Csummary\u003E\u5F15\u7528\u5757\u4E0E\u6B63\u6587\u7684\u95F4\u8DDD\u53CA\u7F29\u8FDB\u3002\u003C/summary\u003E\r\n    60|    public float BlockquotePadding { get; set; } = 8f;\r\n    61|    public float BlockquoteIndent { get; set; } = 14f;\r\n    62|\r\n    63|    /// \u003Csummary\u003E\u5217\u8868\u9879\u76F8\u5BF9\u5217\u8868\u8FB9\u7F18\u7684\u7F29\u8FDB\u3002\u003C/summary\u003E\r\n    64|    public float ListItemIndent { get; set; } = 20f;\r\n    65|\r\n    66|    /// \u003Csummary\u003E\u811A\u6CE8\u533A\u5757\u9876\u90E8\u7559\u767D\u3002\u003C/summary\u003E\r\n    67|    public float FootnoteTopMargin { get; set; } = 24f;\r\n    68|\r\n    69|    /// \u003Csummary\u003E\u5B9A\u4E49\u5217\u8868\u672F\u8BED\u4E0E\u5B9A\u4E49\u7684\u7F29\u8FDB\u5DEE\u3002\u003C/summary\u003E\r\n    70|    public float DefinitionListIndent { get; set; } = 24f;\r\n    71|\r\n    72|    /// \u003Csummary\u003E\u6B63\u6587\u6587\u672C\u989C\u8272\u3002\u003C/summary\u003E\r\n    73|    public uint TextColor { get; set; } = 0xFFD4D4D4;\r\n    74|    /// \u003Csummary\u003E\u6574\u9875\u80CC\u666F\u8272\uFF08Markdown \u6E32\u67D3\u533A\u57DF\u5E95\u8272\uFF09\u3002\u003C/summary\u003E\r\n    75|    public uint PageBackground { get; set; } = 0xFF1E1E1E;\r\n    76|    public uint TableBorderColor { get; set; } = 0xFFD0D7DE;\r\n    77|    public uint TableHeaderBackground { get; set; } = 0xFFF6F8FA;\r\n    78|\r\n    79|    public uint CodeBackground { get; set; } = 0xFF252526;\r\n    80|    public uint CodeKeywordColor { get; set; } = 0xFF569CD6;\r\n    81|    public uint CodeStringColor { get; set; } = 0xFFCE9178;\r\n    82|    public uint CodeCommentColor { get; set; } = 0xFF6A9955;\r\n    83|    public uint CodeNumberColor { get; set; } = 0xFFB5CEA8;\r\n    84|    public uint CodeDefaultColor { get; set; } = 0xFFD4D4D4;\r\n    85|    public uint MathBackground { get; set; } = 0xFF252526;\r\n    86|    public uint SelectionColor { get; set; } = 0x503399FF; // \u9ED8\u8BA4\u5E26\u900F\u660E\u5EA6\u7684\u9AD8\u4EAE\r\n    87|    public uint ImagePlaceholderColor { get; set; } = 0xFF404040;\r\n    88|    public uint LinkColor { get; set; } = 0xFF3794FF;\r\n    89|\r\n    90|    /// \u003Csummary\u003EMarkdown \u5D4C\u5165\u56FE\u9884\u89C8\u89E3\u7801\u65F6\u6700\u957F\u8FB9\u50CF\u7D20\u4E0A\u9650\uFF08\u4E0E\u89C6\u53E3\u63A8\u7B97\u503C\u53D6 min\uFF09\u3002\u003C/summary\u003E\r\n    91|    public int ImagePreviewMaxLongEdgeCap { get; se\n[truncated]",
