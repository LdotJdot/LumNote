      "content": "MarkdownEditor/Controls/EngineRenderControl.cs\r\n70:    /// \u003Csummary\u003E\u5E03\u5C40\u521A\u5E94\u7528\u540E\u7684\u4E0B\u4E00\u6B21 ScrollOffset \u53D8\u5316\u5FFD\u7565\uFF08\u7531 extent \u53D8\u5316\u5F15\u8D77\uFF09\uFF0C\u907F\u514D\u201C\u5E03\u5C40\u5B8C\u6210\u2192ScrollChanged\u2192\u518D\u6B21\u5E03\u5C40\u201D\u7684\u7EA7\u8054\u3002\u003C/summary\u003E\r\n76:    /// \u003Csummary\u003E\u4E0A\u6B21 OnSizeChanged \u65F6\u7684\u5BBD\u5EA6\uFF0C\u4EC5\u5F53\u5BBD\u5EA6\u53D8\u5316\u65F6\u91CD\u7F6E\u5F15\u64CE\uFF0C\u907F\u514D\u9AD8\u5EA6\u53D8\u5316\uFF08\u5185\u5BB9\u5E03\u5C40\u5B8C\u6210\uFF09\u89E6\u53D1\u91CD\u7F6E\u5BFC\u81F4\u95EA\u70C1\u5FAA\u73AF\u3002\u003C/summary\u003E\r\n127:    /// \u003Csummary\u003E\u5E03\u5C40\u5FEB\u7167\u5E94\u7528\u5B8C\u6210\u540E\u89E6\u53D1\uFF0C\u4F9B\u7236\u7EA7\u5728\u5237\u65B0/\u7A97\u53E3\u5C3A\u5BF8\u6539\u53D8\u540E\u6309\u6EDA\u52A8\u767E\u5206\u6BD4\u6062\u590D\u4F4D\u7F6E\u3002\u003C/summary\u003E\r\n137:    public bool TryScrollToDocumentOffset(int documentOffset)\r\n157:    /// \u003Csummary\u003E\u5E03\u5C40\u4EFB\u52A1\u662F\u5426\u6B63\u5728\u6267\u884C\u3002\u4E3A true \u65F6\uFF0C\u811A\u6CE8\u8DF3\u8F6C\u3001Todo \u52FE\u9009\u7B49\u4F9D\u8D56\u5E03\u5C40\u7684\u4EA4\u4E92\u53EF\u88AB\u9650\u5236\u6216\u63D0\u793A\u201C\u7B49\u5F85\u66F4\u65B0\u201D\u3002\u003C/summary\u003E\r\n306:    /// \u003Csummary\u003E\u89E6\u53D1\u540E\u53F0\u89E3\u6790\u002B\u5E03\u5C40\u4EFB\u52A1\uFF0C\u5B8C\u6210\u540E\u5728 UI \u7EBF\u7A0B\u5E94\u7528\u5FEB\u7167\u5E76\u5237\u65B0\u3002\u003C/summary\u003E\r\n434:    /// \u5E03\u5C40\u521A\u5B8C\u6210\u65F6\u4F1A\u6291\u5236\u4E0B\u4E00\u6B21\u6EDA\u52A8\u89E6\u53D1\u7684\u9632\u6296\u5E03\u5C40\uFF1B\u82E5\u7D27\u63A5\u7740\u53D1\u751F\u811A\u6CE8\u7A0B\u5E8F\u5316\u6EDA\u52A8\uFF0C\u8BE5\u6B21\u53D8\u5316\u4F1A\u8BEF\u6D88\u8D39\u6291\u5236\u6807\u5FD7\uFF0C\r\n551:                            || url.StartsWith(\u0022todo-toggle:\u0022, StringComparison.Ordinal)\r\n603:                    else if (url.StartsWith(\u0022todo-toggle:\u0022, StringComparison.Ordinal))\r\n609:                            var lineOpt = engine?.GetTodoSourceLineForListBlock(\r\n617:                                var idx = FindTodoMarkerOnLineByIndex(text, lineOpt.Value);\r\n663:    /// \u5728\u7ED9\u5B9A\u6587\u672C\u4E2D\uFF0C\u5B9A\u4F4D\u7B2C lineIndex \u884C\uFF080-based\uFF09\u4E0A\u7684 ToDo \u6807\u8BB0 \u0022[ ]\u0022 \u6216 \u0022[x]\u0022 \u7684\u5168\u5C40\u8D77\u59CB\u4F4D\u7F6E\u3002\r\n664:    /// \u82E5\u8BE5\u884C\u65E0 ToDo \u6216\u884C\u53F7\u8D8A\u754C\u5219\u8FD4\u56DE -1\u3002\u907F\u514D Substring \u4EE5\u51CF GC\u3002\r\n666:    private static int FindTodoMarkerOnLineByIndex(string text, int lineIndex)\r\n898:            bool isTodo =\r\n899:                h.linkUrl != null \u0026\u0026 h.linkUrl.StartsWith(\u0022todo-toggle:\u0022, StringComparison.Ordinal);\r\n901:            if (!isTodo \u0026\u0026 !string.IsNullOrEmpty(h.linkUrl))\r\n962:        // \u4EC5\u5F53\u5BBD\u5EA6\u53D8\u5316\u65F6\u91CD\u7F6E\u5F15\u64CE\uFF1B\u9AD8\u5EA6\u53D8\u5316\u901A\u5E38\u7531\u5185\u5BB9\u5E03\u5C40\u5B8C\u6210\u89E6\u53D1\uFF0C\u82E5\u6B64\u65F6\u91CD\u7F6E\u4F1A\u5BFC\u81F4\u95EA\u70C1\u5FAA\u73AF\r\n\r\nMarkdownEditor/Controls/MarkdownEngineView.axaml.cs\r\n118:                // \u4EC5\u5355\u5B57\u7B26\u53D8\u66F4\uFF08\u5982 todo \u52FE\u9009\uFF09\u65F6\u7ACB\u5373\u5237\u65B0\u9884\u89C8\uFF0C\u907F\u514D\u5EF6\u8FDF\u4E0E\u4E0D\u540C\u6B65\r\n250:        // \u5EF6\u540E\u5230\u5E03\u5C40\u5B8C\u6210\u540E\u518D\u6062\u590D\uFF0C\u786E\u4FDD Extent \u5DF2\u66F4\u65B0\r\n330:    /// \u003Csummary\u003E\u662F\u5426\u4E3A\u5355\u5B57\u7B26\u5DEE\u5F02\uFF08\u5982 todo [ ]\u2194[x]\uFF09\uFF0C\u7528\u4E8E\u8DF3\u8FC7 debounce \u7ACB\u5373\u5237\u65B0\u3002\u003C/summary\u003E\r\n\r\nMarkdownEditor/docs/analysis-long-document-performance.md\r\n15:| \u0060ApplyLayoutSnapshot\u0060 | \u5E03\u5C40\u5B8C\u6210\u5