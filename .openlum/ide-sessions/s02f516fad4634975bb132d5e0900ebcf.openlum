      "content": "== _chk/Sample.md ==\r\n     1|# Welcome to Leanote! \u6B22\u8FCE\u6765\u5230Leanote!9871abc\r\n     2|\r\n     3|## 1. \u6392\u7248\r\n     4| \r\n     5|**\u7C97\u4F53** *\u659C\u4F53* \r\n     6| \r\n     7|~~\u8FD9\u662F\u4E00\u6BB5\u9519\u8BEF\u7684\u6587\u672C\u3002~~123ss\r\n     8| \r\n     9|\u5F15\u7528:\r\n    10| \r\n    11|\u003E \u5F15\u7528Leanote\u5B98\u65B9\u7684\u8BDD, \u4E3A\u4EC0\u4E48\u8981\u505ALeanote, \u539F\u56E0\u662F...\r\n    12| \r\n    13|00\r\n    14|---\r\n    15|$\u002B123\r\n    16|$\r\n    17|\r\n    18| as\r\n    19| sss\r\n    20|ccc\r\n    21|vvvccc\r\n    22|\r\n    23|\r\n    24|\u6709\u5145\u5217\u8868:\r\n    25| 1. \u652F\u6301Vim\r\n    26| 2. \u652F\u6301Emacs\r\n    27| \r\n    28|\u65E0\u5E8F\u5217\u8868:\r\n    29| \r\n    30| - \u9879\u76EE1\r\n    31| - \u9879\u76EE2\r\n    32| \r\n    33|- [x] Write the press release\r\n    34|- [x] Update the website\r\n    35|- [x] Contact the media\r\n    36|  \r\n    37| \r\n    38|## 2. \u56FE\u7247\u4E0E\u94FE\u63A5\r\n    39| \r\n    40| \r\n    41| ![\u56FE\u7247](\u202AD:/Desktop/pdf.png)\r\n    42| \r\n    43| [\u94FE\u63A5](../../../C3\u5DE5\u827A.png)\r\n    44| \r\n    45| ![\u56FE\u7247](../../../\u8BBE\u5907\u6E05\u5355.png)\r\n    46| \r\n    47|\u56FE\u7247:\r\n    48|![leanote](http://leanote.com/images/logo/leanote_icon_blue.png)\r\n    49|\u94FE\u63A5:\r\n    50| \r\n    51|[\u8FD9\u662F\u53BB\u5F80Leanote\u5B98\u65B9\u535A\u5BA2\u7684\u94FE\u63A5](http://leanote.leanote.com)\r\n    52| \r\n    53|## 3. \u6807\u9898\r\n    54| \r\n    55|\u4EE5\u4E0B\u662F\u5404\u7EA7\u6807\u9898, \u6700\u591A\u652F\u63015\u7EA7\u6807\u9898\r\n    56| \r\n    57|\u0060\u0060\u0060\r\n    58|# h1\r\n    59|## h2\r\n    60|### h3\r\n    61|#### h4\r\n    62|##### h4\r\n    63|###### h5\r\n    64|\u0060\u0060\u0060\r\n    65|\r\n    66|- [x] Write the press release\r\n    67|- [x] Update the website\r\n    68|- [x] Contact the media\r\n    69| \r\n    70|## 4. \u4EE3\u7801\r\n    71| \r\n    72|\u793A\u4F8B:\r\n    73| \r\n    74|    function get(key) {\r\n    75|        return m[key];\r\n    76|    }\r\n    77|    \r\n    78|\u4EE3\u7801\u9AD8\u4EAE\u793A\u4F8B:\r\n    79| \r\n    80|\u0060\u0060\u0060 javascript\r\n    81|/**\r\n    82|* nth element in the fibonacci series.\r\n    83|* @param n \u003E= 0\r\n    84|* @return the nth element, \u003E= 0.\r\n    85|*/\r\n    86|function fib(n) {\r\n    87|  var a = 1, b = 1;\r\n    88|  var tmp;\r\n    89|  while (--n \u003E= 0) {\r\n    90|    tmp = a;\r\n    91|    a \u002B= b;\r\n    92|    b = tmp;\r\n    93|  }\r\n    94|  return a;\r\n    95|}\r\n    96| \r\n    97|document.write(fib(10));\r\n    98|\u0060\u0060\u0060\r\n    99| \r\n   100|\u0060\u0060\u0060python\r\n... [151 more lines, 251 total]\r\n\r\n== MarkdownEditor/Sample_Math.md ==\r\n     1|# MathLaTeX \u516C\u5F0F\u901F\u67E5\u624B\u518C\r\n     2|\r\n     3|$\\sqrt{\\sqrt{\\sqrt{\\sqrt{\\sqrt{\\sqrt{2}}}}}} = \\frac{\\sqrt{\\sqrt{\\sqrt{\\sqrt{\\sqrt{\\sqrt{2}}}}}}}{\\frac{2}{3}}$\r\n     4|\r\n     5|${{{x^{2^2}}^2}^2}^2$\r\n     6|\r\n     7|$3\u002B \\sqrt{{\\sqrt[1\u002B{\\sqrt{3}^2}]{x^2 \u002B y^2}}^2}-1$\r\n     8|\r\n     9|${{{x^2}^2}^2}^2$\r\n    10|\r\n    11|## \u4E00\u3001\u5206\u6570 (Fractions)123321axzzzzzzzz\r\n    12|\r\n    13|### \u884C\u5185\u5206\u6570\r\n    14|\u8FD9\u662F\u884C\u5185\u5206\u6570 $a/b$ \u6216 $\\frac{a}{b}$ \u7684\u793A\u4F8B\u3002\r\n    15|\r\n    16|### \u72EC\u7ACB\u663E\u793A\u5206\u6570\r\n    17|$$\r\n    18|\\frac{a}{b}\r\n    19|$$\r\n    20|\r\n    21|### \u590D\u6742\u5206\u6570\r\n    22|$$\r\n    23|\\frac{\\partial f}{\\partial x} = \\frac{x^2 \u002B y^2}{2xy} \\quad \\text{\u6216} \\quad \\frac{1}{1\u002B\\frac{1}{x}}\r\n    24|$$\r\n    25|\r\n    26|---\r\n    27|\r\n    28|## \u4E8C\u3001\u77E9\u9635 (Matrices)\r\n    29|\r\n    30|### 1. \u65E0\u62EC\u53F7\u77E9\u9635 (matrix)\r\n    31|$$\r\n    32|\\begin{matrix}\r\n    33|a \u0026 b \\\\\r\n    34|c \u0026 d\r\n    35|\\end{matrix}\r\n    36|$$\r\n    37|\r\n    38|### 2. \u5706\u62EC\u53F7\u77E9\u9635 (pmatrix)\r\n    39|$$\r\n    40|\\begin{pmatrix}\r\n    41|a \u0026 b \\\\\r\n    42|c \u0026 d\r\n    43|\\end{pmatrix}\r\n    44|$$\r\n    45|\r\n    46|### 3. \u65B9\u62EC\u53F7\u77E9\u9635 (bmatrix) \u2B50\u6700\u5E38\u7528\r\n    47|$$\r\n    48|\\begin{bmatrix}\r\n    49|a \u0026 b \\\\\r\n    50|c \u0026 d\r\n    51|\\end{bmatrix}\r\n    52|$$\r\n    53|\r\n    54|### 4. \u82B1\u62EC\u53F7\u77E9\u9635 (Bmatrix)\r\n    55|$$\r\n    56|\\begin{Bmatrix}\r\n    57|a \u0026 b \\\\\r\n    58|c \u0026 d\r\n    59|\\end{Bmatrix}\r\n    60|$$\r\n    61|\r\n    62|### 5. \u884C\u5217\u5F0F (vmatrix)\r\n    63|$$\r\n    64|\\begin{vmatrix}\r\n    65|a \u0026 b \\\\\r\n    66|c \u0026 d\r\n    67|\\end{vmatrix}\r\n    68|$$\r\n    69|\r\n    70|### 6. \u53CC\u7AD6\u7EBF\u77E9\u9635 (Vmatrix)\r\n    71|$$\r\n    72|\\begin{Vmatrix}\r\n    73|a \u0026 b \\\\\r\n    74|c \u0026 d\r\n    75|\\end{Vmatrix}\r\n    76|$$\r\n    77|\r\n    78|---\r\n    79|\r\n    80|## \u4E09\u3001\u590D\u6742\u77E9\u9635\u793A\u4F8B\r\n    81|\r\n    82|### 3\u00D73 \u77E9\u9635\r\n    83|$$\r\n    84|\\mathbf{A} = \\begin{bmatrix}\r\n    85|a_{11} \u0026 a_{12} \u0026 a_{13} \\\\\r\n    86|a_{21} \u0026 a_{22} \u0026 a_{23} \\\\\r\n    87|a_{31} \u0026 a_{32} \u0026 a_{33}\r\n    88|\\end{bmatrix}\r\n    89|$$\r\n    90|\r\n    91|### \u589E\u5E7F\u77E9\u9635\r\n    92|$$\r\n    93|\\left[\\begin{array}{ccc|c}\r\n    94|1 \u0026 2 \u0026 3 \u0026 4 \\\\\r\n    95|5 \u0026 6 \u0026 7 \u0026 8 \\\\\r\n    96|9 \u0026 10 \u0026 11 \u0026 12\r\n    97|\\end{array}\\right]\r\n    98|$$\r\n    99|\r\n   100|### \u5206\u5757\u77E9\u9635\r\n... [126 more lines, 226 total]\r\n",
