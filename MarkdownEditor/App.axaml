<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MarkdownEditor.App"
             x:CompileBindings="True"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <!-- 界面样式默认值（深色），运行时由 config 的 ui:style:dark / ui:style:light 覆盖 -->
    <SolidColorBrush x:Key="WindowBackground" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="TitleBarBackground" Color="#252526"/>
    <SolidColorBrush x:Key="TitleBarForeground" Color="#f3f3f3"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#252526"/>
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#3f3f46"/>
    <SolidColorBrush x:Key="SidebarHeaderBackground" Color="#333333"/>
    <SolidColorBrush x:Key="SidebarTextForeground" Color="#cccccc"/>
    <SolidColorBrush x:Key="ExplorerHeaderBackground" Color="#2d2d30"/>
    <SolidColorBrush x:Key="ExplorerHeaderForeground" Color="#cccccc"/>
    <SolidColorBrush x:Key="WelcomePageBackground" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="WelcomePageTextForeground" Color="#cccccc"/>
    <SolidColorBrush x:Key="WelcomePageLinkForeground" Color="#3794ff"/>
    <SolidColorBrush x:Key="TabBarBackground" Color="#252526"/>
    <SolidColorBrush x:Key="TabBarBorderBrush" Color="#3f3f46"/>
    <SolidColorBrush x:Key="ContentBackground" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="EditorForeground" Color="#d4d4d4"/>
    <SolidColorBrush x:Key="StatusBarBackground" Color="#007acc"/>
    <SolidColorBrush x:Key="StatusBarForeground" Color="White"/>
    <SolidColorBrush x:Key="FileChangedBarBackground" Color="#3e3e3e"/>
    <SolidColorBrush x:Key="FileChangedBarForeground" Color="#d4d4d4"/>
    <SolidColorBrush x:Key="ButtonForeground" Color="#f3f3f3"/>
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#3e3e3e"/>
    <SolidColorBrush x:Key="ButtonPressedBackground" Color="#2d2d2d"/>
    <SolidColorBrush x:Key="TabItemForeground" Color="#cccccc"/>
    <SolidColorBrush x:Key="TabItemSelectedForeground" Color="#ffffff"/>
    <SolidColorBrush x:Key="TabItemHoverBackground" Color="#3a3d41"/>
    <SolidColorBrush x:Key="TabItemSelectedBackground" Color="#333333"/>
    <SolidColorBrush x:Key="InputBackground" Color="#3c3c3c"/>
    <SolidColorBrush x:Key="InputForeground" Color="#f3f3f3"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3f3f46"/>
    <SolidColorBrush x:Key="SplitterBorderBrush" Color="#3f3f46"/>
    <SolidColorBrush x:Key="ListBoxItemSelectedBackground" Color="#094771"/>
    <SolidColorBrush x:Key="ListBoxItemSelectedForeground" Color="White"/>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />

    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml"/>

    <!-- 样式由 DynamicResource 绑定到配置，切换主题时从 config 注入 -->
    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
      <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource TitleBarForeground}"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ListBoxItemSelectedBackground}"/>
      <Setter Property="Foreground" Value="{DynamicResource ListBoxItemSelectedForeground}"/>
    </Style>

    <!-- 浅色主题仅保留 RequestedThemeVariant，具体颜色由注入的 LightStyle 提供 -->
  </Application.Styles>
</Application>
