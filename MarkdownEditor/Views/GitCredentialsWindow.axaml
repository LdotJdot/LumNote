<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MarkdownEditor.Views.GitCredentialsWindow"
        Title="Git 认证"
        Width="360"
        Height="180"
        MinWidth="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackground}">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="16">
    <TextBlock x:Name="MessageText"
               Text="请输入用户名和密码（或 Personal Access Token）"
               FontSize="11"
               Foreground="{DynamicResource EditorForeground}"
               TextWrapping="Wrap"
               Margin="0,0,0,8"/>
    <TextBox x:Name="UsernameBox"
             PlaceholderText="用户名"
             FontSize="12"
             Padding="6,4"
             Margin="0,0,0,6"/>
    <TextBox x:Name="PasswordBox"
             PasswordChar="•"
             PlaceholderText="密码或 Token"
             FontSize="12"
             Padding="6,4"
             Margin="0,0,0,12"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="OkButton" Content="确定" MinWidth="72" Padding="10,4"/>
      <Button x:Name="CancelButton" Content="取消" MinWidth="72" Padding="10,4"/>
    </StackPanel>
  </Grid>
</Window>
