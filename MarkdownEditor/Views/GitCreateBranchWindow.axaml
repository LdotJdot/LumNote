<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MarkdownEditor.Views.GitCreateBranchWindow"
        Title="新建分支"
        Width="320"
        Height="140"
        MinWidth="280"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackground}">
  <Grid RowDefinitions="Auto,Auto,Auto" Margin="16">
    <TextBlock Text="输入新分支名称（建议小写、无空格）："
               FontSize="11"
               Foreground="{DynamicResource EditorForeground}"
               Margin="0,0,0,8"/>
    <TextBox x:Name="BranchNameBox"
             Watermark="例如：feature-notes"
             FontSize="12"
             Padding="6,4"
             Margin="0,0,0,12"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="OkButton" Content="确定" MinWidth="72" Padding="10,4"/>
      <Button x:Name="CancelButton" Content="取消" MinWidth="72" Padding="10,4"/>
    </StackPanel>
  </Grid>
</Window>
