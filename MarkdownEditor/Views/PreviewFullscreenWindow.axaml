<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarkdownEditor.Controls"
        xmlns:vm="clr-namespace:MarkdownEditor.ViewModels"
        xmlns:conv="clr-namespace:MarkdownEditor.Converters"
        x:Class="MarkdownEditor.Views.PreviewFullscreenWindow"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="True"
        Title="预览演示"
        Width="400"
        Height="300"
        WindowStartupLocation="Manual"
        WindowDecorations="None"
        Background="{Binding Config.Markdown.BackgroundColor, Converter={x:Static conv:HexToBrushConverter.Instance}}">
  <Window.Styles>
    <Style Selector="controls|MarkdownEngineView ScrollViewer">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </Window.Styles>

  <Panel>
    <Border IsVisible="{Binding ShowPreviewImageWhenNotDiffing}"
            Background="{Binding Config.Markdown.BackgroundColor, Converter={x:Static conv:HexToBrushConverter.Instance}}">
      <controls:ImagePanZoomViewer SourcePath="{Binding PreviewImagePath}"/>
    </Border>
    <controls:MarkdownEngineView IsVisible="{Binding ShowPreviewImageWhenNotDiffing, Converter={x:Static conv:InverseBoolConverter.Instance}}"
                                 Markdown="{Binding CurrentMarkdown}"
                                 MarkdownPreviewUpdatesEnabled="True"
                                 StyleConfig="{Binding Config.Markdown}"
                                 ZoomLevel="{Binding PreviewZoomLevel}"
                                 Background="{Binding Config.Markdown.BackgroundColor, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
  </Panel>
</Window>
